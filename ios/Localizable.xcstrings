        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "See võrguaadress ei tundu olema õige võrguaadressi moodi. Kas salvestame ta ikkagi?\n%@"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette URL à l'air invalide. Sauvegarder quand même ?\n%@"
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Este URL non semella válido. Gardar igualmente?\n%@"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo URL non sembra valido. Vuoi salvarlo comunque?\n%@"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Deze URL lijkt niet juist. Toch opslaan?\n%@"

    "session_renewDialogMessage" : {
      "comment" : "The message of the confirmation dialog to renew the session.",
      "extractionState" : "manual",
      "localizations" : {
        "af" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The server refuses the current session token. You will need to log in again to resume the synchronization."
          }
        },
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الخادم يرفض رمز الجلسة الحالي. ستحتاج إلى تسجيل الدخول مرة أخرى لاستئناف المزامنة."
          }
        },
        "ca" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El servidor rebutja el testimoni de sessió actual. Haureu d’iniciar sessió de nou per a reprendre la sincronització."
          }
        },
        "cs" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The server refuses the current session token. You will need to log in again to resume the synchronization."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Server lehnt den aktuellen Session Token ab. Du wirst dich erneut einloggen müssen um dir Synchronisierung fortsetzen zu können."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The server refuses the current session token. You will need to log in again to resume the synchronization."
          }
        },
        "eo" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La servilo rifuzas la nunan sesioĵetonon. Vi devos ensaluti denove por rekomenci la sinkronigon."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El servidor rechaza el token de la sesión actual. Deberá iniciar sesión nuevamente para reanudar la sincronización."
          }
        },
        "et" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Server keeldub praeguse tunnusloa kaotamisest. Sünkroniseerimise jätkamiseks pead uuesti sisse logima."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le serveur refuse le jeton de session actuel. Vous devrez vous connecter à nouveau pour reprendre la synchronisation."
          }
        },
        "fy" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "The server refuses the current session token. You will need to log in again to resume the synchronization."
          }
        },
        "gl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O servidor rexeita o token de sesión actual. Terás que acceder outra vez para continuar coa sincronización."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il server non accetta il token della sessione attuale. Devi accedere nuovamente per riprendere la sincronizzazione."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "De server weigert het huidige sessietoken. U moet zich opnieuw aanmelden om de synchronisatie te hervatten."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O servidor recusa o token de sessão atual. Precisará efetuar login novamente para retomar a sincronização."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O servidor recusa o token de sessão atual. Você precisará efetuar login novamente para retomar a sincronização."
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O servidor recusa o token de sessão atual. Precisará efetuar login novamente para retomar a sincronização."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сервер отказывается использовать токен текущего сеанса. Чтобы возобновить синхронизацию, необходимо снова войти в систему."
          }
        },
        "ta" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "சேவையகம் தற்போதைய அமர்வு கிள்ளாக்கை மறுக்கிறது. ஒத்திசைவை மீண்டும் தொடங்க நீங்கள் மீண்டும் உள்நுழைய வேண்டும்."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Máy chủ từ chối token phiên hiện tại. Bạn sẽ cần phải đăng nhập lại để tiếp tục đồng bộ hóa."
          }
        },
        "zh" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "服务器拒绝当前会话令牌。您需要重新登录才能恢复同步。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "伺服器拒絕目前工作階段令牌。你需要重新登入以恢復同步。"
          }
        }
      }
    },

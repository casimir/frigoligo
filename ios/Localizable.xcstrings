    "save_dubiousUrlMessage": {
      "comment": "The message of the dubious URL warning dialog.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "هذا الرابط لا يبدو صحيحًا. هل تريد حفظه على أي حال؟\n%@"

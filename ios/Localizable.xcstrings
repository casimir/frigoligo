    "settings_clearCacheMessage": {
      "comment": "The message of the confirmation dialog to clear the cache.",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سيتم حذف الذاكرة المؤقتة المحلية وجلبها مرة أخرى من الخادم."
          }
        },
        "ca": {
          "stringUnit": {
            "state": "translated",
            "value": "La memòria cau local se suprimirà i es recuperarà del servidor un cop més."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der lokale Cache wird gelöscht und erneut vom Server abgerufen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The local cache will be deleted and fetched again from the server."
          }
        },
        "eo": {
          "stringUnit": {
            "state": "translated",
            "value": "La loka kaŝmemoro estos forigita kaj denove elŝutita de la servilo."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La caché local se eliminará y se recuperará nuevamente del servidor."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Järgnevaga kustutame kohaliku vahemälu ja laadime andmed serverist uuesti."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le cache local sera supprimé et récupéré à nouveau depuis le serveur."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaise eliminar a caché local e solicitar outra vez os datos ao servidor."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La cache locale verrà eliminata e recuperata nuovamente dal server."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De lokale cache wordt verwijderd en opnieuw opgehaald van de server."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "O cache local será apagado e recuperado novamente do servidor."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O cache local será excluído e recuperado novamente do servidor."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O cache local será apagado e recuperado novamente do servidor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Локальный кэш будет удалён и снова получен с сервера."
          }
        },
        "ta": {
          "stringUnit": {
            "state": "translated",
            "value": "உள்ளக கேச் நீக்கப்பட்டு மீண்டும் சேவையகத்திலிருந்து பெறப்படும்."
          }
        },
        "zh": {
          "stringUnit": {
            "state": "translated",
            "value": "本地缓存将被删除，并重新从服务器获取。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "本機快取將會被刪除並再次從伺服器獲取。"
          }
        }
      }
    },
